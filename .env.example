# Copier ce fichier en « .env » puis renseigner les valeurs réelles.
# Ne JAMAIS committer le fichier .env (il contient des secrets).

# --- Sécurité ---
DJANGO_SECRET_KEY=changez-moi-par-une-cle-aleatoire-longue
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://intranet.lpmconsulting.cm

# Déconnexion automatique après inactivité (secondes)
SESSION_EXPIRE_SECONDS=1800

# --- Base de données ---
# Laisser vide pour SQLite (dev). Mettre « postgresql » pour la production.
DB_ENGINE=
DB_NAME=intranet_lpm
DB_USER=lpm
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Email (récupération mot de passe / notifications) ---
# Laisser EMAIL_HOST vide en dev (les emails s'affichent dans la console).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=intranet@lpmconsulting.cm

# --- Coordonnées légales (papier en-tête des documents PDF) ---
LPM_NAME=LPM CONSULTING GROUP
LPM_TAGLINE=L'expression de votre marque
LPM_SUBTITLE=Votre agence panafricaine
LPM_ADDRESS=Akwa-Nord, 100 m après la pharmacie, immeuble rose, 3ème niveau
LPM_BP=B.P. Douala – Cameroun
LPM_PHONE=+237 233 410 029
LPM_EMAIL=lucprosper.moni@lpmconsultinggroup.com
LPM_WEBSITE=www.lpmconsultinggroup.com
LPM_RCCM=RC/DLA/2014/B/4112
LPM_NIU=M101412172020J

# --- Pointage : géo-clôture (présence au bureau) ---
LPM_GEOFENCE_ENABLED=True
LPM_OFFICE_LAT=4.0530
LPM_OFFICE_LNG=9.7060
LPM_OFFICE_RADIUS_M=250
# Restriction réseau (complément au GPS) : IP publiques du bureau (préfixe accepté)
LPM_IP_RESTRICTION=False
LPM_OFFICE_IPS=154.72.,41.202.

# --- Notifications ---
NOTIFY_EMAIL=True
SITE_BASE_URL=http://127.0.0.1:8000

# --- Production ---
SECURE_SSL_REDIRECT=True
